# Tuesday — Environment Variables
# Copy this to .env and fill in your keys.

# Required
ANTHROPIC_API_KEY=sk-ant-...

# TTS (optional — voice won't work without this)
ELEVENLABS_API_KEY=
TUESDAY_VOICE_ID=pNInz6obpgDQGcFmaJgB

# Web search (optional — get free key at https://brave.com/search/api/)
BRAVE_SEARCH_API_KEY=

# GitHub (optional — create at https://github.com/settings/tokens)
# Needs: repo, read:user scopes
GITHUB_TOKEN=

# Gmail (optional — personal email integration)
# Register app at https://console.cloud.google.com > APIs & Services > Credentials
# Enable Gmail API, add redirect URI: http://localhost:8000/auth/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/gmail/callback

# Microsoft Outlook (optional — Phase 3 calendar + email)
# Register app at https://portal.azure.com > App Registrations
# Redirect URI: http://localhost:8000/auth/outlook/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:8000/auth/outlook/callback

# Auth (optional — set to protect your deployed instance)
# Generate one: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
TUESDAY_AUTH_TOKEN=

# Model (optional)
TUESDAY_MODEL=claude-sonnet-4-6
TUESDAY_MAX_TOKENS=4096

# Environment
TUESDAY_ENV=production
